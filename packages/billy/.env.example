# Anthropic API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Finout credentials (inherited from parent .env or set here)
FINOUT_CLIENT_ID=your_finout_client_id
FINOUT_SECRET_KEY=your_finout_secret_key
FINOUT_API_URL=https://app.finout.io
# Backward-compatible alias (optional):
# FINOUT_INTERNAL_API_URL=https://app.finout.io
FINOUT_ACCOUNT_ID=your_account_id
