FROM python:3.11-slim

WORKDIR /app

COPY packages/mcp-server /app/packages/mcp-server
COPY packages/mcp-server-hosted /app/packages/mcp-server-hosted
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir /app/packages/mcp-server && \
    pip install --no-cache-dir /app/packages/mcp-server-hosted

ENV MCP_HOST=0.0.0.0
ENV MCP_PORT=8080
EXPOSE 8080

CMD ["finout-mcp-hosted"]
