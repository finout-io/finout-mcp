# IMPORTANT: This is an EXAMPLE template
# DO NOT commit actual secrets to git!
#
# To create the actual secret:
# 1. Copy this file: cp billy-secret.yaml.example billy-secret.yaml
# 2. Replace placeholder values
# 3. Apply: kubectl apply -f billy-secret.yaml
# 4. Delete the file or ensure it's in .gitignore

apiVersion: v1
kind: Secret
metadata:
  name: billy-secrets
  namespace: billy
  labels:
    app: billy
type: Opaque
stringData:
  # Required
  anthropic-api-key: "REPLACE_ME"
  database-url: "postgresql://USERNAME:PASSWORD@HOST:5432/DB_NAME"

  # Optional: only needed if MCP tools require direct Finout API auth
  # finout-client-id: "REPLACE_ME"
  # finout-secret-key: "REPLACE_ME"

  # Optional: needed to enable Langfuse tracing from Billy/MCP
  # langfuse-public-key: "pk-lf-..."
  # langfuse-secret-key: "sk-lf-..."

---
# Or use external secret management (recommended for production)
# Example with Azure Key Vault:
#
# apiVersion: spv.no/v2beta1
# kind: AzureKeyVaultSecret
# metadata:
#   name: billy-secrets
#   namespace: billy
# spec:
#   vault:
#     name: your-keyvault
#     object:
#       name: finout-client-id
#       type: secret
#   output:
#     secret:
#       name: billy-secrets
#       dataKey: finout-client-id
